{
  "name": "koudmain-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "format:fix": "prettier --write \"src/**/*{.ts,.js}\" \"test/**/*{.ts,.js}\" \"migrations/**/*{.ts,.js}\" \"seeders/**/*{.ts,.js}\"",
    "format:check": "prettier --check \"src/**/*{.ts,.js}\" \"test/**/*{.ts,.js}\" \"migrations/**/*{.ts,.js}\" \"seeders/**/*{.ts,.js}\"",
    "lint:fix": "eslint \"{src,apps,libs}/**/*.{ts,js}\" --fix",
    "lint:check": "eslint \"{src,apps,libs}/**/*.{ts,js}\"",
    "test": "docker exec -it koudmain-backend npx jest --config ./test/jest.unit.js",
    "test:watch": "jest --watch",
    "test:cov": "docker exec -it koudmain-backend npx jest --config ./test/jest.unit.js --coverage",
    "test:debug": "docker exec -it koudmain-backend node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "docker exec -it koudmain-backend npx jest --config ./test/jest-e2e.json",
    "test:supertest": "docker exec -it koudmain-backend npx jest --config ./test/jest.supertest.js",
    "test:ci": "jest --config ./test/jest.unit.js --ci --runInBand --coverage",
    "test:e2e:ci": "jest --config ./test/jest-e2e.json --ci --runInBand",
    "db:test:migrate:ci": "sequelize-cli db:migrate --env test",
    "db:test:seed:ci": "sequelize-cli db:seed:all --env test",
    "db:test:migrate": "docker exec -it koudmain-backend npx sequelize-cli db:migrate --env test",
    "db:test:seed": "docker exec -it koudmain-backend npx sequelize-cli db:seed:all --env test",
    "db:test:reset": "docker exec -it koudmain-backend sh -c \"npx sequelize-cli db:drop --env test && npx sequelize-cli db:create --env test && npx sequelize-cli db:migrate --env test\"",
    "db:migrate": "docker exec -it koudmain-backend npx sequelize-cli db:migrate",
    "db:migrate:undo": "docker exec -it koudmain-backend npx sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "docker exec -it koudmain-backend npx sequelize-cli db:migrate:undo:all",
    "db:seed": "docker exec -it koudmain-backend npx sequelize-cli db:seed:all",
    "db:reset": "docker exec -it koudmain-backend sh -c \"npx sequelize-cli db:drop && npx sequelize-cli db:create && npx sequelize-cli db:migrate\"",
    "db:backup": "docker exec -t koudmain-db pg_dump -U ${DB_USER:-postgres} -h ${DB_HOST:-localhost} -p ${DB_PORT:-5432} ${DB_NAME:-koudmain} > backup_$(date +%Y%m%d_%H%M%S).sql",
    "db:backup:schema": "docker exec -t koudmain-db pg_dump -U ${DB_USER:-postgres} -h ${DB_HOST:-localhost} -p ${DB_PORT:-5432} -s ${DB_NAME:-koudmain} > backup_schema_$(date +%Y%m%d_%H%M%S).sql"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/sequelize": "^11.0.1",
    "@sequelize/postgres": "^7.0.0-alpha.48",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "node-mailjet": "^6.0.11",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.4.0",
    "@jest-performance-reporter/core": "^2.1.3",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^16.0.0",
    "jest": "^30.3.0",
    "jest-junit": "^17.0.0",
    "jest-sonar": "^0.2.16",
    "prettier": "3.8.1",
    "sequelize-cli": "^6.6.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "file-type": "^21.3.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
